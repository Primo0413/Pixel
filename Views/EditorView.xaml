<UserControl x:Class="pixel_edit.Views.EditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:pixel_edit.Models"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="14" CornerRadius="12" Background="White" BorderBrush="#1F000000" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="{Binding Title}" Style="{StaticResource MaterialDesignTitleLargeTextBlock}" TextWrapping="Wrap" />

                    <ToggleButton IsChecked="{Binding EraserMode}" Content="橡皮模式" Margin="0,12,0,10" />

                    <TextBlock Text="调色板" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <ListBox ItemsSource="{Binding Project.Palette}" SelectedItem="{Binding SelectedColor}" Height="560">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:PaletteEntry}">
                                <DockPanel Margin="0,3">
                                    <Border Width="20" Height="20" CornerRadius="3" BorderBrush="#22000000" BorderThickness="1" Margin="0,0,8,0"
                                            Background="{Binding Hex, Converter={StaticResource HexToBrushConverter}}" />
                                    <TextBlock Text="{Binding Alias}" Width="40" />
                                    <TextBlock Text="{Binding Hex}" Opacity="0.8" />
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="#0A000000" CornerRadius="12" Padding="12">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Cells}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="{Binding DataContext.Project.Canvas.Width, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:PixelCell}">
                                <Border Width="12" Height="12" Margin="0" BorderThickness="0.5" BorderBrush="#22000000" Background="{Binding Brush}">
                                    <Border.InputBindings>
                                        <MouseBinding Gesture="LeftClick" Command="{Binding DataContext.PaintCellCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" />
                                    </Border.InputBindings>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource ActionBarBackgroundBrush}"
                CornerRadius="12"
                Padding="12">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="返回首页" Command="{Binding BackHomeCommand}" Style="{StaticResource ActionBarButtonStyle}" />
                    <Button Content="导入并转换图片" Command="{Binding ImportAndConvertImageCommand}" Style="{StaticResource ActionBarButtonStyle}" />
                    <Button Content="加载工程" Command="{Binding LoadProjectCommand}" Style="{StaticResource ActionBarButtonStyle}" />
                    <Button Content="删除选中像素" Command="{Binding DeleteSelectedPixelCommand}" Style="{StaticResource ActionBarButtonStyle}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button Content="导出PNG" Command="{Binding ExportPngCommand}" Style="{StaticResource ActionBarButtonStyle}" />
                    <Button Content="保存工程" Command="{Binding SaveProjectCommand}" Style="{StaticResource PrimaryActionBarButtonStyle}" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>

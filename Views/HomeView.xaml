<UserControl x:Class="pixel_edit.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Style="{StaticResource PageRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource SettingsCardStyle}" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="欢迎使用 Pixel Edit"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="#FF1B1B1B" />

                <TextBlock Grid.Row="1"
                           Margin="0,10,0,0"
                           Text="在左侧导航中选择功能：图片转换、白板绘制、或项目拼接/堆叠。"
                           Foreground="#FF555555"
                           TextWrapping="Wrap" />

                <Border Grid.Row="3" Style="{StaticResource SettingsCardStyle}" Background="#FFF9F9F9" Padding="14">
                    <StackPanel>
                        <TextBlock Text="建议流程" FontWeight="SemiBold" />
                        <TextBlock Text="1) 导入图片生成像素图" Margin="0,8,0,0" Foreground="#FF444444" />
                        <TextBlock Text="2) 在编辑器微调并保存 .pxproj.json" Margin="0,6,0,0" Foreground="#FF444444" />
                        <TextBlock Text="3) 导出 PNG，或进入组合页继续拼接" Margin="0,6,0,0" Foreground="#FF444444" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource SettingsCardStyle}"
                Background="{StaticResource ActionBarBackgroundBrush}"
                Padding="12">
            <TextBlock Text="从左侧选择一个开始动作"
                       VerticalAlignment="Center"
                       Foreground="#FF666666" />
        </Border>
    </Grid>
</UserControl>
